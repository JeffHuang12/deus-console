# DEUS Console 後端環境變數範本
# 複製為 .env 並填入實際值(此檔可進版控,真實值不可)

# ─── Claude / LLM ───────────────────────────────────────────────────────────
# 走 Claude Code CLI 訂閱可留空；明確走 Anthropic API 則填入
ANTHROPIC_API_KEY=

# 預設推論模型；前端 PromptPage 可覆寫
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001

# Claude Code CLI 路徑；留空時 SDK 自行尋找
CLAUDE_CLI_PATH=

# ─── GA4 ────────────────────────────────────────────────────────────────────
GA4_PROPERTY_ID=
GA4_OAUTH_CLIENT_SECRET=
GA4_OAUTH_TOKEN_PATH=

# 可用此路徑覆寫 .env 載入位置（通常不需設定）
# GA4_DOTENV_PATH=

# ─── Google Cloud / BigQuery ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
BIGQUERY_DATASET=
# Service account JSON 路徑（ADC 模式）
GOOGLE_APPLICATION_CREDENTIALS=
# 同義備用鍵（舊版相容）
GOOGLE_PROJECT_ID=

# ─── Shopline ────────────────────────────────────────────────────────────────
SHOPLINE_ACCESS_TOKEN=

# ─── Google Ads ──────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Meta Marketing API ──────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ─── LINE ────────────────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ─── Search Console / Bing ───────────────────────────────────────────────────
SEARCH_CONSOLE_SITE_URL=
BING_API_KEY=

# ─── Gemini（GA4 備選路徑）──────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Boxful / Firecrawl ──────────────────────────────────────────────────────
BOXFUL_API_KEY=
FIRECRAWL_API_KEY=
